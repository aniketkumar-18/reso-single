# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model for agent ReAct loops (more capable)
LLM_MODEL_AGENT=gpt-4o
# Model for fast pipeline calls (classifier, router, synthesizer)
LLM_MODEL_PIPELINE=gpt-4o-mini

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
# Service role key — bypasses RLS; never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
# Must match the JWT secret configured in Supabase → Settings → API
JWT_SECRET=super-secret-jwt-secret-change-me
JWT_ALGORITHM=HS256

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=reso-orchestrator

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info
CONTEXT_MESSAGE_LIMIT=30
MEMORY_LOOKBACK_DAYS=7
